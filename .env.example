OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_PREDICT=900
OLLAMA_NUM_CTX=4096
OLLAMA_MAX_RESUME_CHARS=8000
OLLAMA_MAX_RESUME_PAGES=1
