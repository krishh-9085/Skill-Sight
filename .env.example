VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
VITE_SUPABASE_STORAGE_BUCKET=resumes

# Server-only env var (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# For Ollama Cloud, set to your API key. Leave blank for local Ollama.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
# Optional: false|true|low|medium|high. For GPT-OSS on cloud, "low" is recommended.
OLLAMA_THINK_LEVEL=false
OLLAMA_TIMEOUT_MS=120000
OLLAMA_NUM_PREDICT=900
OLLAMA_NUM_CTX=4096
OLLAMA_MAX_RESUME_CHARS=8000
OLLAMA_MAX_RESUME_PAGES=1

# Recommended Ollama Cloud preset for gpt-oss:120b-cloud:
# OLLAMA_BASE_URL=https://ollama.com/api
# OLLAMA_MODEL=gpt-oss:120b-cloud
# OLLAMA_THINK_LEVEL=low
# OLLAMA_TIMEOUT_MS=120000
# OLLAMA_NUM_PREDICT=1400
# OLLAMA_NUM_CTX=8192
